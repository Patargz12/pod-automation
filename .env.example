# Printify Personal Access Token
# Generate at: Printify Dashboard -> My Profile -> Connections -> Generate
# Required scopes: shops.read, catalog.read, uploads.read, uploads.write,
#                  products.read, products.write
PRINTIFY_API_TOKEN=

# Optional: force a specific shop. Leave blank to auto-detect (first Etsy-connected,
# else first shop). Find the id printed by the script, or via GET /v1/shops.json
PRINTIFY_SHOP_ID=

# Google Gemini API keys — used to AI-generate the SEO title, description and
# tags for each design (Gemini 2.5 Flash looks at the design image).
# Get keys at Google AI Studio: https://aistudio.google.com → Get API key.
# The keys form a rotating pool: when one hits its quota/rate limit, the next
# one takes over automatically. Fill in as many as you have (blanks are skipped);
# if none work, listings fall back to a placeholder.
GEMINI_API_KEY_1=
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=
GEMINI_API_KEY_4=
GEMINI_API_KEY_5=
